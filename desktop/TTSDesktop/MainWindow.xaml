<Window x:Class="TTSDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TTS Propio Desktop"
        Height="760"
        Width="1120"
        MinHeight="720"
        MinWidth="980"
        Background="#0F172A">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827" CornerRadius="16" Padding="18" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="TTS Propio" FontSize="28" FontWeight="Bold"/>
                <TextBlock Margin="0,8,0,0"
                           Text="Interfaz de escritorio para entrenar tu voz, revisar logs y probar el modelo sin depender de localhost."/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="#111827" BorderThickness="0" Padding="6">
            <TabItem Header="Entrenamiento">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Rutas esperadas" Grid.Row="0">
                        <TextBlock x:Name="PathsTextBlock" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </GroupBox>

                    <GroupBox Header="Acciones" Grid.Row="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Validar archivos" Click="OnPreflightClick"/>
                            <Button Content="Preparar dataset" Click="OnPrepareClick"/>
                            <Button Content="Entrenar modelo" Click="OnTrainClick"/>
                            <Button Content="Pipeline completo" Click="OnPipelineClick"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Logs" Grid.Row="2">
                        <TextBox x:Name="LogsTextBox"
                                 FontFamily="Consolas"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Probar modelo">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Texto a sintetizar" Grid.Row="0">
                        <TextBox x:Name="PromptTextBox"
                                 Height="110"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </GroupBox>

                    <GroupBox Header="Acciones" Grid.Row="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Generar audio" Click="OnSynthesizeClick"/>
                            <Button Content="Reproducir audio" Click="OnPlayClick"/>
                            <Button Content="Abrir carpeta de salida" Click="OnOpenOutputClick"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Ultimo resultado" Grid.Row="2">
                        <TextBlock x:Name="LatestAudioTextBlock" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </GroupBox>

                    <GroupBox Header="Historial" Grid.Row="3">
                        <TextBox x:Name="HistoryTextBox"
                                 FontFamily="Consolas"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"/>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
